# Citizen's Dashboard - Environment Variables
# Copy this file to .env and fill in your values

# OpenAI / OpenRouter API Key (required for summarization and embeddings)
OPENAI_API_KEY=sk-or-v1-your-openrouter-key-here

# Optional base URL override.
# If you use an OpenRouter key (sk-or-v1...), this should be:
# OPENAI_API_BASE=https://openrouter.ai/api/v1
# If omitted, the app now auto-detects sk-or-v1 keys and sets this automatically.
OPENAI_API_BASE=https://openrouter.ai/api/v1

# OpenAI model for the dashboard pipeline
OPENAI_MODEL=gpt-4o-mini

# ScaleDown API Key (required for token compression)
SCALEDOWN_API_KEY=your-scaledown-key-here

# ScaleDown compression rate
SCALEDOWN_RATE=auto

# PageIndex Path (required - clone the repo first)
# Run: git clone https://github.com/VectifyAI/PageIndex.git
PAGEINDEX_PATH=./PageIndex
# Free OpenRouter model for PageIndex (avoids credit costs). Options:
# meta-llama/llama-3.3-70b-instruct:free  |  google/gemma-3-27b-it:free  |  mistralai/mistral-small-3.1-24b-instruct:free
PAGEINDEX_MODEL=meta-llama/llama-3.3-70b-instruct:free

# PageIndex uses the same key under its own env var name
CHATGPT_API_KEY=sk-or-v1-your-openrouter-key-here
